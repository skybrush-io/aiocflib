from typing import Iterable, Literal, overload

def dump(binary: bytes, size: int = 2, sep: str = " ") -> str: ...
def dumpgen(data: bytes) -> Iterable[str]: ...
@overload
def hexdump(data: bytes, result: Literal["print"]) -> None: ...
@overload
def hexdump(data: bytes, result: Literal["return"]) -> str: ...
@overload
def hexdump(data: bytes, result: Literal["generator"]) -> Iterable[str]: ...
@overload
def hexdump(
    data: bytes, result: Literal["print", "return", "generator"] = "print"
) -> None | str | Iterable[str]: ...
